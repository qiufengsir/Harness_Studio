{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "memory": "512",
    "cpu": "1"
  },
  "environments": {
    "production": {
      "variables": {
        "DATABASE_PATH": "/data/dev.db",
        "HOSTNAME": "0.0.0.0",
        "PORT": "3000"
      }
    }
  }
}
