# ============================================================
# Harness Studio — .gitignore
# Next.js + Node + SQLite + IDE
# ============================================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/

# ---- Next.js build ----
.next/
out/
build/
dist/
.open-next/

# ---- Production ----
*.tsbuildinfo
next-env.d.ts

# ---- Environment ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Database (SQLite) ----
*.db
*.db-journal
*.db-wal
*.db-shm
dev.db*
harness-studio/dev.db*
harness-studio/*.db

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# ---- OS files ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Trae IDE rules (project-local, keep) ----
# .trae/rules/  # 注释掉：保留项目规则
.trae/cache/
.trae/workspace/

# ---- Test / coverage ----
coverage/
*.lcov
.nyc_output/

# ---- Misc ----
.cache/
.turbo/
*.pem
.vercel
