{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd harness-studio && npm ci && npm run build",
    "nixpacksConfig": {
      "phases": {
        "install": {
          "cmd": "cd harness-studio && npm ci"
        },
        "build": {
          "cmd": "cd harness-studio && npm run build"
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd harness-studio && npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "memory": "512",
    "cpu": "1"
  },
  "environments": {
    "production": {
      "variables": {
        "DATABASE_PATH": "/data/dev.db",
        "HOSTNAME": "0.0.0.0",
        "PORT": "3000"
      }
    }
  }
}
